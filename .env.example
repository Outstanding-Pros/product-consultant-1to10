# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Server-side only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PayApp REST (Korea)
PAYAPP_USER_ID=your_payapp_userid
PAYAPP_PRICE_BASIC=9500
PAYAPP_PRICE_PRO=29500
PAYAPP_OPENPAYTYPE=card,phone,kakaopay,naverpay,tosspay
PAYAPP_FEEDBACK_TOKEN=your_random_token

# International (Polar.sh) checkout session
POLAR_ACCESS_TOKEN=polar_at_your_token_here
POLAR_SERVER=production
POLAR_PRICE_BASIC=7
POLAR_PRICE_PRO=20
POLAR_PRODUCT_ID_BASIC=your_basic_product_id
POLAR_PRODUCT_ID_PRO=your_pro_product_id

# Polar webhook verification (official signature)
POLAR_WEBHOOK_SECRET=whsec_your_secret_here
